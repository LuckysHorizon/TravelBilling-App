# ============================================================
# TravelBilling — Environment Variables Reference
# Copy this to .env and fill in your values
# ============================================================

# --- Database ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/travelbill
SPRING_DATASOURCE_USERNAME=travelbill
SPRING_DATASOURCE_PASSWORD=devpassword
DATABASE_URL=postgresql://travelbill:devpassword@localhost:5432/travelbill

# --- Backend ---
SERVER_PORT=8080
JWT_SECRET=your-256-bit-secret-here
CORS_ORIGIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
NVIDIA_API_KEY=

# --- Python PDF Extractor ---
EXTRACTION_SERVICE_URL=http://localhost:8000/extract
EXTRACTION_HEALTH_URL=http://localhost:8000/health
GROQ_API_KEY=
GROQ_MODEL=llama-3.2-90b-vision-preview
PDF_SERVICE_API_KEY=your-internal-api-key

# --- Cloudflare R2 Storage ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=travelbilling-pdfs
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8080
VITE_PDF_SERVICE_URL=http://localhost:8000

# --- Monitoring ---
UPTIME_ROBOT_API_KEY=

# --- Email ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
